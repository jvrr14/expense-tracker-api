# PostgreSQL connection string
#
# Local Docker (run: docker compose up -d)
DATABASE_URL=postgresql://expense_user:expense_pass@localhost:5432/expense_tracker
#
# Neon cloud (https://console.neon.tech → Connection string)
# DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# JWT signing secret — must be at least 32 characters
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Server port (defaults to 3000 if omitted)
PORT=3000

# Runtime environment
NODE_ENV=development
